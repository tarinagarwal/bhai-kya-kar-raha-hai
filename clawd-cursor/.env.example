# Clawd Cursor — Environment Variables
# Copy this to .env and fill in your values

# AI Provider API Key (pick one)
AI_API_KEY=

# Provider: anthropic | openai | ollama | kimi | gemini | vertexai
# If not set, auto-detected from API key format
# AI_PROVIDER=anthropic

# Or use provider-specific keys:
# ANTHROPIC_API_KEY=sk-ant-api03-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=AIza...

# ── Google Gemini / Vertex AI ──
# Option 1: Vertex AI (uses gcloud ADC — run `gcloud auth application-default login`)
# USE_VERTEXAI=true
# VERTEXAI_PROJECT=your-gcp-project-id
# VERTEXAI_LOCATION=global
# GEMINI_MODEL=gemini-3-flash-preview

# Option 2: Gemini API key (simpler, no GCP project needed)
# GEMINI_API_KEY=AIza...

# Tip: Run 'npx clawd-cursor doctor' to auto-detect and configure everything
